# 服务监听
HOST=127.0.0.1
PORT=8765

# 浏览器：false 为有头模式（调试推荐）
BROWSER_HEADLESS=false

# 启动时打开的预热页（常驻不关闭，请求在新标签页处理）
BROWSER_WARMUP_URL=https://labs.google/fx/zh/tools/flow

# 打码后额外等待秒数（稳定 enterprise 链路）
BROWSER_RECAPTCHA_SETTLE_SECONDS=2

# 页面与 API 超时（秒）
BROWSER_PAGE_TIMEOUT=60
BROWSER_CAPTCHA_TIMEOUT=30

# 项目页 URL 模板，{project_id} 会被替换
FLOW_PROJECT_URL_TEMPLATE=https://labs.google/fx/tools/flow/project/{project_id}

# Google Flow API（可选，一般无需改）
# FLOW_API_BASE=https://aisandbox-pa.googleapis.com
# FLOW_IMAGE_API_PATH_TEMPLATE=/v1/projects/{project_id}/flowMedia:batchGenerateImages
# FLOW_VIDEO_API_PATH=/v1/video:batchAsyncGenerateVideoText
# FLOW_VIDEO_STATUS_API_PATH=/v1/video:batchCheckAsyncVideoGenerationStatus
